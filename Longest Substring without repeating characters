Given a string s, find the length of the longest substring without duplicate characters.

Example 1:

Input: s = "abcabcbb"
Output: 3
Explanation: The answer is "abc", with the length of 3. Note that "bca" and "cab" are also correct answers.


class Solution(object):
    def lengthOfLongestSubstring(self, s):
        char_set = set()    #initially this will be empty
        left = 0
        max_length = 0
        for right in range(len(s)):
            while s[right] in char_set:
                char_set.remove(s[left])    #this means it will remove one value from that set (basically we only need the max length not the values)
                left+=1
            char_set.add(s[right])          #starting it will come here as the set is empty so here all gets added untill duplicates come , if dupli come it goes inside loop)
            max_length = max(max_length, right - left + 1)    #sliding window 
        return max_length
